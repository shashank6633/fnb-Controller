# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite databases — these contain real production data (sessions, audit
# events, requisitions, costs) and MUST NOT be pushed to a public repo.
*.db
*.db-shm
*.db-wal
*.db.bak*
*.db.backup*
*.sqlite
*.sqlite3
/backups/
/data/

# Local-only Claude / IDE config (launch.json carries personal paths)
/.claude/

# Service account / API key files — defensive even though none live in this
# tree today, this prevents an accidental future commit.
**/service-account*.json
**/google-credentials*.json
**/credentials.json
**/*-keyfile.json
**/secrets/
*.key
*.pkcs8
id_rsa*
id_ed25519*

# Local override / scratch files
*.local
*.local.*
TODO.md.local
NOTES.md.local

# Mac / OS noise
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json.example
/aws-migration/

# ── Captain Android (TWA) build ───────────────────────────────────────────
# NEVER commit the signing keystore or its password — losing/leaking it means
# you can't ship app updates and anyone could sign as you.
captain-android/android.keystore
captain-android/KEYSTORE_README.txt
# Build outputs (large binaries; distribute the APK out-of-band, not via git)
captain-android/*.apk
captain-android/*.aab
captain-android/app/build/
captain-android/.gradle/
captain-android/build/
captain-android/*.idsig
captain-android/local.properties

# Print-bridge runtime files (written next to the .mjs on the counter PC)
public/cache.json
public/kot-outbox.json
scripts/cache.json
scripts/kot-outbox.json
cache.json
kot-outbox.json
